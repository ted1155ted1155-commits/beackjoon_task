#include <stdio.h>

// 사용자 정의 함수
int sum(int n, int n1)  // sum의 인자(매개변수)는 n과 n1이다.
{
    return n + n1;  // 반환 타입이 int이며, n + n1의 결과를 반환
}

// 메인 함수 
int main()
{
    int n, n1;  // 정수형 변수 n과 n1을 선언 
    scanf("%d %d" , &n, &n1);  // 입력, n과 n1을 초기화 
    
    // sum 함수를 호출한 후에 반환한 데이터를 출력
    printf("sum 함수의 호출 결과는 %d이다" , sum(n, n1));  // sum의 인수는 n과 nn1이다
    return 0;
}

