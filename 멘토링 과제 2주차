#include <stdio.h>

int main() {
    int score;

    // 시험 점수 입력 받기
    scanf("%d", &score);

    // 조건에 따라 등급 출력
    if (score >= 90 && score <= 100) {
        printf("A\n");
    }
    else if (score >= 80 && score <= 89) {
        printf("B\n");
    }
    else if (score >= 70 && score <= 79) {
        printf("C\n");
    }
    else if (score >= 60 && score <= 69) {
        printf("D\n");
    }
    else {
        printf("F\n");
    }

    return 0;
}





#include <stdio.h>

int main() {
       int a, b, c;   //3개의 눈을 지정할 변수 선언 
	   
	    // 주사위 눈 입력 받기
		 scanf("%d %d %d", &a, &b, &c);
		 
		 // 같은 눈이 3개인 경우
		     if (a == b && b == c) {
        printf("%d\n", 10000 + a * 1000);
    }
	
	 // 같은 눈이 2개만 있는 경우
    else if (a == b || a == c) {
        printf("%d\n", 1000 + a * 100);
    }
    else if (b == c) {
        printf("%d\n", 1000 + b * 100);
    }
	
	 // 모두 다른 눈이 나오는 경우
    else {
        int max;
        // 가장 큰 눈 구하기
        if (a > b && a > c) {
            max = a;
        } else if (b > c) {
            max = b;
        } else {
            max = c;
        }
        printf("%d\n", max * 100);
    }

    return 0; // 프로그램 정상 종료
}



