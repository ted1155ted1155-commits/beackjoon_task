#include <stdio.h>

int main() {
    int N;
    scanf("%d", &N);

    for (int i = 1; i <= N; i++) {
        // 공백 출력
        for (int j = 0; j < N - i; j++) {
            printf(" ");
        }

        // 별 출력
        for (int j = 0; j < 2 * i - 1; j++) {
            printf("*");
        }

        // 줄 바꿈
        printf("\n");
    }

    return 0;
}
